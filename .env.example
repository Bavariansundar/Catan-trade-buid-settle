# Copy to .env for `docker compose up` — see docs/deployment.md.
# (This is separate from apps/server/.env.example, which is for running
# apps/server directly on the host with `pnpm dev` against a Dockerized
# Postgres/Redis.)

# Required in production — no default. openssl rand -hex 32 (or similar);
# a long random string. Rotating either secret invalidates all existing
# sessions of that kind (access or refresh).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Change this for any deployment reachable outside your own machine.
POSTGRES_PASSWORD=hexhaven

# Comma-separated list of allowed web origins, e.g. https://hexhaven.example.com
# Defaults to "*" (any origin) if unset — fine for local use, not for production.
CORS_ORIGIN=

# The API's public origin, as the browser will reach it. Defaults to
# http://localhost:3001, which is correct for a single-host `docker compose
# up` (the browser reaches both the web app and API via localhost) but
# needs to be the real public API origin, e.g. https://api.hexhaven.example.com,
# for any remote deployment — set CORS_ORIGIN above to the *web app's*
# origin in that case, since they're deliberately two separate origins.
VITE_API_URL=
